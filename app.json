{
  "expo": {
    "name": "remindi",
    "slug": "remindi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#5C85FF"
    },
    "notification": {
      "icon": "./src/assets/notification-icon.png",
      "color": "#5C85FF"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/frame.png",
        "backgroundColor": "#5C85FF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.pedrohzzm.remindi"
    },
    "web": {
      "favicon": "./src/assets/icon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/notification-icon.png",
          "color": "#5C85FF"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0aa16681-ba48-45d5-b966-43ae56cc370a"
      }
    }
  }
}