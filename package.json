{
  "name": "remindi",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/stack": "^7.8.10",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-notifications": "~0.32.16",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "lodash": "^4.18.1",
    "lucide-react-native": "^1.8.0",
    "react": "19.1.0",
    "react-hook-form": "^7.73.1",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1314.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-uuid": "^2.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/react": "~19.1.0",
    "@types/xdate": "^0.8.35",
    "jest-expo": "^55.0.16",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterFramework": [],
    "setupFiles": [
      "./src/tests/unit/setup.ts"
    ],
    "testMatch": [
      "**/tests/unit/repositories/*.test.ts",
      "**/tests/unit/repositories/*.test.tsx"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|lucide-react-native)"
    ],
    "moduleNameMapper": {
      "^expo-sqlite$": "<rootDir>/src/tests/unit/mocks/expo-sqlite.ts",
      "^expo-crypto$": "<rootDir>/src/tests/unit/mocks/expo-crypto.ts",
      "^expo-notifications$": "<rootDir>/src/tests/unit/mocks/expo-notifications.ts"
    }
  },
  "private": true
}